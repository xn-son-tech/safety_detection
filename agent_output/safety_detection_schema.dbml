}

Records camera_criterion_assignments(id, camera_id, criterion_id, is_enabled, created_at, updated_at) {
  '00000000-0000-0000-0000-000000004001', '00000000-0000-0000-0000-000000000101', '00000000-0000-0000-0000-000000002001', true, '2026-01-01 00:00:00', '2026-01-01 00:00:00'
}
